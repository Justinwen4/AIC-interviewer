# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Optional: publishable/anon key (browser); this app’s API uses the service role below.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — paste the service_role secret from Project Settings → API.
# May be a JWT (eyJ...) or newer format (sb_secret_...). Never use sb_publishable_ here.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Admin dashboard login password (min 12 chars); also used to sign admin session cookie
ADMIN_PASSWORD=change-me-to-a-long-random-string
